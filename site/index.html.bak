          <hr class="my-5" />
          <h3 class="text-center">Ball Beam Balance Robot</h3>
          <div class="d-flex flex-wrap justify-content-center gap-4">
            <div class="gallery-item"><img src="./assets/images/BBB_CAD1.webp" class="img-fluid gallery-img"
