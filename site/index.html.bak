<!doctype html>
<html lang="en" data-bs-theme="dark">

<head>
  <meta charset="utf-8" />
  <meta http-equiv="X-UA-Compatible" content="IE=edge" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="view-transition" content="same-origin" />
  <title>Home | RTV</title>
  <script>
    (function () {
      const theme = localStorage.getItem("theme") || "dark";
      document.documentElement.setAttribute("data-bs-theme", theme);
    })();
  </script>
  <link rel="icon" href="./assets/icons/favicon.ico" type="image/x-icon" />
  <link rel="preload" href="./assets/icons/RTVBrandmarkNoOutline.webp" as="image" />
  <link href="./css/bootstrap.min.css" rel="stylesheet" />
  <link rel="stylesheet" href="./css/style.css" />
</head>

<body class="d-flex flex-column min-vh-100">
  <nav class="navbar navbar-expand-lg navbar-dark custom-navbar py-3">
    <div class="container-fluid">
      <a class="navbar-brand d-flex align-items-center fw-bold fs-4" href="./">
        <img src="./assets/icons/RTVBrandmarkNoOutline.webp" alt="RTV Logo" height="40" class="me-2" />
        Home
      </a>

      <div class="d-flex align-items-center order-lg-last">
        <button class="btn theme-btn me-2" id="theme-toggle" type="button" aria-label="Toggle Theme">
          <img id="theme-icon" class="theme-icon-img" src="./assets/icons/lightMode.svg" alt="Toggle theme" width="20"
            height="20" />
        </button>
        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarSupportedContent"
          aria-controls="navbarSupportedContent" aria-expanded="false" aria-label="Toggle navigation">
          <span class="navbar-toggler-icon"></span>
        </button>
      </div>

      <div class="collapse navbar-collapse" id="navbarSupportedContent">
        <ul class="navbar-nav me-auto mb-2 mb-lg-0">
          <li class="nav-item"><a class="nav-link" href="./projectDescription/">Project Description</a></li>
          <li class="nav-item"><a class="nav-link" href="./documents/">Documents</a></li>
          <li class="nav-item"><a class="nav-link" href="./IPR/">Inverted Pendulum Robot</a></li>
          <li class="nav-item"><a class="nav-link" href="./BBB/">Ball Beam Balance Robot</a></li>
        </ul>
      </div>
    </div>
  </nav>

  <div class="container my-5 flex-grow-1">
    <h1 class="text-center mb-4 display-4 fw-bold">Robotics Traveling Van</h1>
    <p class="text-center lead mb-5">
      An interactive K–12 outreach project focused on teaching engineering principles through hands-on robotics
      demonstrations.
    </p>
    <hr class="mb-5" />

    <section class="my-5">
      <h2 class="mb-3">Project Overview</h2>
      <p class="fs-5">
        The Robotics Traveling Van (RTV) project aims to develop portable, engaging robotic systems that introduce K–12
        students to mechanical engineering, electronics, and programming. Our 2025–2026 project includes the development
        of two demonstration robots: an Inverted Pendulum Robot and a Ball Beam Balance Robot. These robots are designed
        to be durable, transportable, and educational, allowing future outreach teams to easily teach core STEM concepts
        through live demonstrations.
      </p>
    </section>

    <ul class="nav nav-tabs nav-fill mb-4" id="myTab" role="tablist">
      <li class="nav-item" role="presentation">
        <button class="nav-link active" id="robots-tab" data-bs-toggle="tab" data-bs-target="#robots-tab-pane"
          type="button" role="tab" aria-controls="robots-tab-pane" aria-selected="true">Robots</button>
      </li>
      <li class="nav-item" role="presentation">
        <button class="nav-link" id="team-tab" data-bs-toggle="tab" data-bs-target="#team-tab-pane" type="button"
          role="tab" aria-controls="team-tab-pane" aria-selected="false">Team</button>
      </li>
    </ul>

    <div class="tab-content" id="myTabContent">
      <div class="tab-pane fade show active" id="robots-tab-pane" role="tabpanel" aria-labelledby="robots-tab"
        tabindex="0">
        <section class="my-5">
          <div class="row g-4">
            <div class="col-lg-6">
              <div class="card shadow-sm h-100">
                <div class="row g-0 align-items-center h-100">
                  <div class="col-md-3 p-3 text-center">
                    <img src="./assets/images/IPR_mainphoto.webp" class="img-fluid robot-card-img"
                      alt="Inverted Pendulum Robot Prototype" />
                  </div>
                  <div class="col-md-9 border-start d-flex flex-column h-100">
                    <div class="card-body d-flex flex-column h-100">
                      <h5 class="card-title fs-4 mb-2">Inverted Pendulum Robot</h5>
                      <p class="card-text">
                        A reaction-wheel-based pendulum robot used to teach concepts such as PID control, angular
                        momentum, and dynamic stability.
                      </p>
                      <div class="mt-auto">
                        <a href="./IPR/" class="btn btn-custom-primary">Learn More</a>
                      </div>
                    </div>
                  </div>
                </div>
              </div>
            </div>

            <div class="col-lg-6">
              <div class="card shadow-sm h-100">
                <div class="row g-0 align-items-center h-100">
                  <div class="col-md-3 p-3 text-center">
                    <img src="./assets/images/BBB_mainphoto.webp" class="img-fluid robot-card-img"
                      alt="Ball Beam Balance Robot Prototype" />
                  </div>
                  <div class="col-md-9 border-start d-flex flex-column h-100">
                    <div class="card-body d-flex flex-column h-100">
                      <h5 class="card-title fs-4 mb-2">Ball Beam Balance Robot</h5>
                      <p class="card-text">
                        A control-theory demonstration robot that uses a stepper-motor-driven beam to balance a rolling
                        ball.
                      </p>
                      <div class="mt-auto">
                        <a href="./BBB/" class="btn btn-custom-primary">Learn More</a>
                      </div>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          </div>
          <div class="mt-5 row justify-content-center align-items-stretch gap-4">
            <div class="col-md-3 d-flex flex-column">
              <h3 class="text-center">Promo Video</h3>
              <div class="d-flex flex-grow-1 align-items-center justify-content-center">
                <video id="promoVideo" controls preload="metadata" poster="./assets/images/promoVideoCover.webp"
                  class="rounded shadow-sm promo-media">
                  <source src="./assets/images/promoVideo720p.webm" type="video/webm">
                  Your browser does not support the HTML5 video tag.
                </video>
              </div>
              <div class="mt-3 text-center">
                <a href="https://youtube.com/shorts/Llqt_Z5niqo" target="_blank" class="btn btn-custom-primary">View on
                  YouTube</a>
              </div>
            </div>

            <div class="col-md-8 d-flex flex-column">
              <h3 class="text-center">Fall 2026 Poster</h3>
              <div class="d-flex flex-grow-1 align-items-center justify-content-center text-center">
                <img src="./assets/documents/Spring2026Poster.webp" alt="Fall 2026 Poster"
                  class="img-fluid rounded shadow-sm promo-media" />
              </div>
              <div class="mt-3 text-center">
                <button type="button" class="btn btn-custom-primary" data-bs-toggle="modal"
                  data-bs-target="#posterModal">View Full Res</button>
              </div>
            </div>
          </div>

          <hr>
          <h2 class="text-center mt-5">Gallery</h2>
          <h3 class="text-center">Inverted Pendulum Robot</h3>
          <div class="d-flex flex-wrap justify-content-center gap-4">
