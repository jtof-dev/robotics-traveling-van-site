            <div class="gallery-item"><img src="./assets/images/BBB_CAD3.webp" class="img-fluid gallery-img"
                alt="CAD Model of BBB" /></div>
            <div class="gallery-item"><img src="./assets/images/BBB_Pic1.webp" class="img-fluid gallery-img"
                alt="Image of BBB" /></div>
            <div class="gallery-item"><img src="./assets/images/BBB_Pic2.webp" class="img-fluid gallery-img"
                alt="Image of BBB" /></div>
            <div class="gallery-item"><img src="./assets/images/BBB_Pic3.webp" class="img-fluid gallery-img"
