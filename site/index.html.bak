            <div class="gallery-item"><img src="./assets/images/IPR_CAD2.webp" class="img-fluid gallery-img"
                alt="CAD Model of IPR" /></div>
            <div class="gallery-item"><img src="./assets/images/IPR_Old_Pic1.webp" class="img-fluid gallery-img"
                alt="Old version of IPR" /></div>
            <div class="gallery-item"><img src="./assets/images/IPR_Old_Pic2.webp" class="img-fluid gallery-img"
                alt="Old version of IPR" /></div>
            <div class="gallery-item"><img src="./assets/images/IPR_Pic1.webp" class="img-fluid gallery-img"
                alt="Image of IPR" /></div>
            <div class="gallery-item"><img src="./assets/images/IPR_Pic2.webp" class="img-fluid gallery-img"
                alt="Image of IPR" /></div>
            <div class="gallery-item"><img src="./assets/images/IPR_Pic3.webp" class="img-fluid gallery-img"
