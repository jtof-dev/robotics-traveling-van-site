      </div>
    </div>
  </div>

  <div class="modal fade" id="posterModal" tabindex="-1" aria-labelledby="posterModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-fullscreen">
      <div class="modal-content custom-modal-overlay">
        <div class="modal-header border-0">
          <h5 class="modal-title text-white" id="posterModalLabel">Fall 2026 Poster</h5>
          <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
        </div>
        <div class="modal-body p-0 modal-flex-center">
          <div
            class="position-absolute bottom-0 start-50 translate-middle-x mb-4 z-3 d-flex gap-2 bg-dark rounded-pill p-2 shadow">

            <button id="zoomOutBtn" class="btn btn-outline-light rounded-circle zoom-control-btn" title="Zoom Out">
              <span class="dynamic-icon icon-zoom-out"></span>
            </button>

            <button id="resetZoomBtn" class="btn btn-outline-light d-flex align-items-center justify-content-center"
              title="Reset Zoom">Reset</button>

            <button id="zoomInBtn" class="btn btn-outline-light rounded-circle zoom-control-btn" title="Zoom In">
              <span class="dynamic-icon icon-zoom-in"></span>
            </button>

          </div>
          <div id="panzoom-container" class="panzoom-wrapper">
            <img src="./assets/documents/Spring2026PosterFullRes.webp" id="panzoom-image" class="panzoom-img"
              alt="Full Res Poster" draggable="false" />
          </div>
        </div>
      </div>
    </div>
  </div>

  <footer class="custom-footer py-4 text-center mt-auto">
    <div class="container">
      <p class="mb-1 fw-medium">Made with love by the RTV Capstone Team</p>
